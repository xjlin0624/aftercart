APP_ENV=development
LOG_LEVEL=INFO

# Local database and cache defaults
POSTGRES_DB=aftercart
POSTGRES_USER=aftercart
POSTGRES_PASSWORD=aftercart
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://aftercart:aftercart@localhost:5432/aftercart

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Celery schedules
PRICE_CHECK_BATCH_SIZE=100
PRICE_CHECK_INTERVAL_MINUTES=15
DELIVERY_CHECK_INTERVAL_MINUTES=60
SUBSCRIPTION_REFRESH_INTERVAL_MINUTES=360

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_ENABLE_CELERY=true

# Playwright scraping
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_TIMEOUT_MS=15000
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=20000
PLAYWRIGHT_STORAGE_STATE_DIR=backend/.playwright/state
SCRAPER_USER_AGENT=AfterCartBot/1.0 (+https://aftercart.app)
SCRAPER_RETRY_ATTEMPTS=3
SCRAPER_BACKOFF_BASE_SECONDS=2
SCRAPER_BACKOFF_MAX_SECONDS=30
SCRAPER_RATE_LIMIT_PER_MINUTE=20
SCRAPER_CIRCUIT_FAILURE_THRESHOLD=5
SCRAPER_CIRCUIT_COOLDOWN_SECONDS=300

# LLM protections
GEMINI_API_KEY=
LLM_CACHE_TTL_SECONDS=900
LLM_RATE_LIMIT_PER_MINUTE=10
LLM_RATE_LIMIT_WINDOW_SECONDS=60
LLM_DEDUPE_TTL_SECONDS=300

# Firebase / FCM
FCM_ENABLED=false
FCM_SERVICE_ACCOUNT_JSON=
FCM_SERVICE_ACCOUNT_FILE=
FCM_DEFAULT_TTL_SECONDS=3600

# Deployment assumptions
RENDER_EXTERNAL_URL=http://localhost:8000
RENDER_DEPLOY_HOOK_URL=
VERCEL_PUBLIC_APP_URL=http://localhost:5173
VERCEL_DEPLOY_HOOK_URL=

# Frontend build-time env vars
VITE_API_BASE_URL=http://localhost:8000/api
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
