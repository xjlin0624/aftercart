APP_ENV=development  # development | production

# Database — use shared Neon URL (ask a teammate)
DATABASE_URL=postgresql+psycopg://aftercart:aftercart@localhost:5432/aftercart

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

PRICE_CHECK_BATCH_SIZE=100
PRICE_CHECK_INTERVAL_MINUTES=15
SUBSCRIPTION_REFRESH_INTERVAL_MINUTES=360

LOG_LEVEL=INFO  # DEBUG in dev, INFO/WARNING in production

# Auth — MUST be changed to a strong random secret in production
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Gemini — get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Production only — comma-separated frontend URLs
# Example: ALLOWED_ORIGINS=https://aftercart.vercel.app,https://www.aftercart.com
# Leave empty in development (localhost origins are used automatically)
ALLOWED_ORIGINS=
